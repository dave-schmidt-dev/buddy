#!/bin/sh
# buddy — pre-commit gate. Runs the full local gate (ruff lint + format-check +
# pytest) automatically before every commit. No CI, nothing to run by hand.
#
# Activated by pointing git at this tracked directory:
#     git config core.hooksPath hooks
# which `make install` / `make hooks` does for you. git deliberately never
# auto-activates hooks from a clone, so that one-time wiring is the only setup.
exec make check
